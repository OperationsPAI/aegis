
# Workspace-local backup artifacts (Phase 1 dumps etc.)
.backup/
*.bak

# Editor / OS noise
.DS_Store
.vscode/
.idea/
*.swp

# Anything prefixed with _tmp
_tmp*/

# Workbuddy local runtime state
.workbuddy/*
!.workbuddy/.gitignore

# cache
.cache
.aegisctl
.kube


# Loop campaign artifacts — cache subdirs (cloned source repos for analysis) are large + reproducible
experiments/*/cache/
experiments/*/.cache/

# Loop campaign — transient enumeration / replay scratch (not part of the dataset)
experiments/_supported/
experiments/_replay/
