{
  "round": 999,
  "system": "ts",
  "system_type": "ts",
  "pedestal": {"name": "ts", "tag": "1.0.0"},
  "benchmark": {"name": "clickhouse", "tag": "1.0.0"},
  "defaults": {"interval": 10, "pre_duration": 5},
  "_strategy": "Retry: TT R3 failed candidates after submit_dual.py container-fallback fix",
  "candidates": [
    {"id": "tt25", "app": "ts-auth-service",   "chaos_type": "JVMException", "params": {"class":"auth.service.impl.UserServiceImpl","method":"findByUserName","exception_opt":"random"}, "duration_override": 10},
    {"id": "tt26", "app": "ts-cancel-service", "chaos_type": "JVMException", "params": {"class":"cancel.service.CancelServiceImpl","method":"cancelOrder","exception_opt":"random"}, "duration_override": 10},
    {"id": "tt34", "app": "ts-order-service",  "chaos_type": "CPUStress",    "params": {"cpu_load":90,"cpu_worker":4}, "duration_override": 15},
    {"id": "tt35", "app": "ts-travel-service", "chaos_type": "CPUStress",    "params": {"cpu_load":90,"cpu_worker":4}, "duration_override": 15},
    {"id": "tt36", "app": "ts-payment-service","chaos_type": "MemoryStress", "params": {"memory_size":512,"mem_worker":2,"mem_type":"ram"}, "duration_override": 15}
  ]
}
