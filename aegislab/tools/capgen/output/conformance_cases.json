  },
  {
    "name": "jvm_mysql_exception",
    "chaos_type": "JVMMySQLException",
    "conformance_probe": {
      "expect": "\u003e baseline + 0.8",
      "probe": "trace.db.span.error_rate"
    }
  },
  {
    "name": "jvm_mysql_latency",
    "chaos_type": "JVMMySQLLatency",
    "conformance_probe": {
      "expect": "\u003e= delay_ms * 0.9",
      "probe": "trace.db.span.duration_ms",
      "scope": "db.statement matches sql_type"
    }
  },
  {
    "name": "jvm_runtime_mutator",
    "chaos_type": "JVMRuntimeMutator",
    "conformance_probe": {
      "note": "app-semantic mutation; no universal probe — needs per-mutation contract",
      "probe": "TODO"
    }
  },
  {
    "name": "memory_stress",
    "chaos_type": "MemoryStress",
    "conformance_probe": {
      "expect": "delta \u003e= size_mib * 0.7 MiB",
      "probe": "container.memory.working_set"
