[
  {
    "name": "container_kill",
    "chaos_type": "ContainerKill",
    "conformance_probe": {
      "expect": "delta \u003e= 1",
      "probe": "k8s.container.restart_count",
      "scope": "target.container"
    }
  },
  {
    "name": "cpu_stress",
    "chaos_type": "CPUStress",
    "conformance_probe": {
      "expect": "rate \u003e= baseline + load_pct * 0.5",
      "probe": "container.cpu.utilization"
    }
  },
  {
    "name": "dns_error",
    "chaos_type": "DNSError",
    "conformance_probe": {
      "expect": "\u003e baseline + 0.5",
      "note": "TODO: resolver TTL caveat",
      "probe": "trace.egress.error_rate"
    }
  },
  {
    "name": "dns_random",
    "chaos_type": "DNSRandom",
    "conformance_probe": {
      "note": "manifestation depends on caller retry/timeout; no single observable holds across stacks",
      "probe": "TODO"
    }
  },
  {
    "name": "http_request_abort",
    "chaos_type": "HTTPRequestAbort",
    "conformance_probe": {
      "expect": "\u003e 0.9",
      "probe": "trace.error_rate",
      "scope": "target.endpoint"
    }
  },
  {
    "name": "http_request_delay",
    "chaos_type": "HTTPRequestDelay",
    "conformance_probe": {
      "expect": "\u003e= delay_ms * 0.9",
      "probe": "trace.span.duration_ms"
    }
  },
  {
    "name": "http_request_replace_method",
    "chaos_type": "HTTPRequestReplaceMethod",
    "conformance_probe": {
      "expect": "== new_method OR span.status_code in {405, 404}",
      "probe": "trace.span.http.method"
    }
  },
  {
    "name": "http_request_replace_path",
    "chaos_type": "HTTPRequestReplacePath",
    "conformance_probe": {
      "expect": "== new_path OR span.error_rate \u003e baseline + 0.5",
      "probe": "trace.span.http.route"
    }
  },
  {
    "name": "http_response_abort",
    "chaos_type": "HTTPResponseAbort",
    "conformance_probe": {
      "expect": "\u003e 0.9",
      "probe": "trace.error_rate",
      "scope": "target.endpoint"
    }
  },
  {
    "name": "http_response_delay",
    "chaos_type": "HTTPResponseDelay",
    "conformance_probe": {
      "expect": "\u003e= delay_ms * 0.9",
      "probe": "trace.span.duration_ms"
    }
  },
  {
    "name": "http_response_patch_body",
    "chaos_type": "HTTPResponsePatchBody",
    "conformance_probe": {
      "note": "body diff is not visible in spans by default; needs response-body capture or downstream error correlation",
      "probe": "TODO"
    }
  },
  {
    "name": "http_response_replace_body",
    "chaos_type": "HTTPResponseReplaceBody",
    "conformance_probe": {
      "expect": "\u003e baseline + 0.5",
      "note": "TODO: requires client instrumentation",
      "probe": "client.parse_error_rate"
    }
  },
  {
    "name": "http_response_replace_code",
    "chaos_type": "HTTPResponseReplaceCode",
    "conformance_probe": {
      "expect": "== status_code for \u003e= 0.9 of target-endpoint spans",
      "probe": "trace.span.http.status_code"
    }
  },
  {
    "name": "jvm_cpu_stress",
    "chaos_type": "JVMCPUStress",
    "conformance_probe": {
      "expect": "delta \u003e= cpu_count * 0.5 cores",
      "probe": "container.cpu.utilization"
    }
  },
  {
    "name": "jvm_gc",
    "chaos_type": "JVMGarbageCollector",
    "conformance_probe": {
      "expect": "delta \u003e= 1",
      "note": "TODO: needs JVM metrics exporter",
      "probe": "jvm.gc.collection_count"
    }
  },
  {
    "name": "jvm_memory_stress",
    "chaos_type": "JVMMemoryStress",
    "conformance_probe": {
      "expect": "delta \u003e 0.5 * baseline",
      "note": "TODO: stack mode → span error_rate instead",
      "probe": "jvm.memory.used_bytes"
    }
  },
  {
    "name": "jvm_method_exception",
    "chaos_type": "JVMException",
    "conformance_probe": {
      "expect": "\u003e baseline + 0.5",
      "probe": "trace.span.error_rate",
