    }
  },
  {
    "name": "network_loss",
    "chaos_type": "NetworkLoss",
    "conformance_probe": {
      "expect": "\u003e baseline + loss_pct/200",
      "probe": "trace.edge.error_or_retry_rate"
    }
  },
  {
    "name": "network_partition",
    "chaos_type": "NetworkPartition",
    "conformance_probe": {
      "expect": "\u003e 0.9",
      "probe": "trace.edge.error_rate"
    }
  },
  {
    "name": "pod_failure",
    "chaos_type": "PodFailure",
    "conformance_probe": {
