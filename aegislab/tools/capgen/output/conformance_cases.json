    }
  },
  {
    "name": "jvm_method_latency",
    "chaos_type": "JVMLatency",
    "conformance_probe": {
      "expect": "\u003e= delay_ms * 0.9",
      "note": "TODO: needs span coverage on target method",
      "probe": "trace.span.duration_ms",
      "scope": "span(class.method)"
    }
  },
  {
    "name": "jvm_method_return",
    "chaos_type": "JVMReturn",
    "conformance_probe": {
