# aegislab Environment Configuration
# This file contains environment-specific settings
# Copy this file to .env and fill in your actual values

# Kubernetes Contexts

# Context for development environment
DEV_CONTEXT=your-dev-context

# Context for staging environment
STAGE_CONTEXT=your-stage-context

# Context for production environment
PROD_CONTEXT=your-prod-context

# Context for test environment (e.g., minikube, kind)
TEST_CONTEXT=your-test-context