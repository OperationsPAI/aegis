<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{.Title}} · {{.Slug}}</title>
  <link rel="stylesheet" href="/static/pages/github-markdown.css">
  <link rel="stylesheet" href="/static/pages/chroma-github.css">
  <style>
    body { display: grid; grid-template-columns: 240px 1fr; max-width: 1200px; margin: 0 auto; padding: 32px; gap: 24px; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
    aside.sidebar { border-right: 1px solid #d0d7de; padding-right: 16px; }
    aside.sidebar ul { list-style: none; padding: 0; margin: 0; }
    aside.sidebar li { margin: 4px 0; }
    aside.sidebar a { color: #0969da; text-decoration: none; }
    aside.sidebar a.active { font-weight: 600; }
    @media (max-width: 768px) { body { grid-template-columns: 1fr; } aside.sidebar { display: none; } }
  </style>
</head>
<body>
  <aside class="sidebar">
    <h3>{{.SiteTitle}}</h3>
    <ul>
      {{range .NavItems}}<li><a href="{{.URL}}"{{if .Active}} class="active"{{end}}>{{.Label}}</a></li>{{end}}
    </ul>
  </aside>
  <main class="markdown-body">{{.Body}}</main>
</body>
</html>
