<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{.Title}} · {{.Slug}}</title>
  <link rel="stylesheet" href="/static/pages/github-markdown.css">
  <link rel="stylesheet" href="/static/pages/chroma-github.css">
  <link rel="stylesheet" href="/static/pages/layout.css">
  <!-- KaTeX for $…$ / $$…$$ math. Loads from jsDelivr; pages still render
       cleanly (with raw $…$ source) if the CDN is blocked. -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" crossorigin="anonymous">
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js" crossorigin="anonymous"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js" crossorigin="anonymous"
    onload="renderMathInElement(document.body, {delimiters:[{left:'$$',right:'$$',display:true},{left:'$',right:'$',display:false},{left:'\\(',right:'\\)',display:false},{left:'\\[',right:'\\]',display:true}],throwOnError:false});"></script>
</head>
<body>
  <aside class="sidebar">
    <h3>{{.SiteTitle}}</h3>
    <ul class="files">
      {{range .NavItems}}
      <li class="file{{if .Active}} active{{end}}{{if .IsMD}} md{{else}} raw{{end}}">
        <a class="file-link" href="{{.URL}}" title="{{.Path}}">
          <span class="file-icon" aria-hidden="true">{{if .IsMD}}M{{else}}·{{end}}</span>
          <span class="file-name">{{.Label}}</span>
          <span class="file-size">{{.SizeText}}</span>
        </a>
        {{if .IsMD}}<a class="file-raw" href="{{.RawURL}}" title="View raw source">raw</a>{{end}}
      </li>
      {{end}}
    </ul>
  </aside>
  <main class="markdown-body">{{.Body}}</main>
  <!-- Mermaid: promote chroma-rendered `<pre><code class="language-mermaid">`
       blocks into `<div class="mermaid">` so mermaid.run() can pick them up.
       chroma wraps the contents in syntax-highlighting spans, so we walk the
       textContent rather than innerHTML. -->
  <script type="module">
    import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@10.9.1/dist/mermaid.esm.min.mjs";
    document.querySelectorAll('pre > code.language-mermaid, pre > code[class*="language-mermaid"]').forEach((code) => {
      const div = document.createElement('div');
      div.className = 'mermaid';
      div.textContent = code.textContent;
      code.closest('pre').replaceWith(div);
    });
    mermaid.initialize({ startOnLoad: false, theme: 'default' });
    await mermaid.run();
  </script>
</body>
</html>
